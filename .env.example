# Supabase project settings (Project Settings > API)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Only used by server-side Server Actions that need elevated access (backup/restore).
# NEVER expose this to the client. Not required for normal CRUD (RLS handles that with the anon key + user session).
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# IANA timezone used for "same calendar day" edit/delete windows, daily report boundaries, etc.
# Sri Varahi Building Solutions is based in Andhra Pradesh, India.
NEXT_PUBLIC_BUSINESS_TIMEZONE=Asia/Kolkata
